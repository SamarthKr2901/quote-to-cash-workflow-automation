        "jsCode": "const now = new Date();\nconst todayStart = now.toISOString().slice(0, 10) + 'T00:00:00.000Z';\nconst base = 'https://{{SUPABASE_PROJECT_URL}}/rest/v1/escalations?';\nconst orClause = '(last_notified_at.is.null,last_notified_at.lt.' + todayStart + ')';\nconst encodedOr = encodeURIComponent(orClause);\nconst quoteUrl = base + 'type=eq.quote_reminder&resolved=eq.false&notification_count=lt.3&or=' + encodedOr + '&select=id,lead_id,notification_count';\nconst payUrl = base + 'type=eq.payment_reminder&resolved=eq.false&or=' + encodedOr + '&select=id,lead_id,notification_count';\nreturn [{ json: { todayStart, quoteUrl, payUrl } }];"
      },
