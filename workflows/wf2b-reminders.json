      "parameters": {
        "fromEmail": "developer@example.com",
        "toEmail": "={{ $json.lead_email }}",
        "subject": "={{ 'Day ' + $json.day_num + ' of 3 — Your Apex Windows Quote is Still Waiting' }}",
        "html": "={{ '<div style=\"font-family:Arial;max-width:620px;margin:0 auto\"><div style=\"background:#4A148C;padding:22px 16px;border-radius:8px 8px 0 0\"><h1 style=\"color:#fff;margin:0;font-size:22px\">Apex Windows TX</h1><p style=\"color:#CE93D8;margin:6px 0 0\">Quote Reminder &#8212; Day ' + $json.day_num + ' of 3</p></div><div style=\"padding:24px;background:#fafafa\"><p>Hi ' + $json.lead_name + ',</p><p>This is a friendly reminder that your personalised quote from Apex Windows TX is still awaiting your response.</p>' + ($json.is_last_reminder ? '<div style=\"background:#FFF3E0;border:1px solid #E65100;border-radius:6px;padding:12px 16px;margin:16px 0;font-size:13px;color:#E65100;font-weight:bold\">&#9888; Final Notice: This is your last reminder. Your quote will expire after today if no action is taken.</div>' : '') + '<table style=\"width:100%;border-collapse:collapse;margin:16px 0\"><tr style=\"background:#4A148C\"><th style=\"color:#fff;padding:9px;text-align:left\">Service</th><th style=\"color:#fff;padding:9px;text-align:right\">Quote Total</th></tr><tr><td style=\"padding:9px\">Window Service</td><td style=\"padding:9px;text-align:right\"><strong>$' + parseFloat($json.total_amount).toFixed(2) + '</strong></td></tr></table><div style=\"text-align:center;margin:28px 0\"><a href=\"' + $json.accept_url + '\" style=\"background:#2E7D32;color:#fff;padding:15px 30px;border-radius:6px;text-decoration:none;font-size:17px;font-weight:bold\">Accept This Quote</a></div><p style=\"text-align:center;font-size:12px;color:#aaa\">Not interested? <a href=\"' + $json.decline_url + '\">Decline here</a></p><p style=\"font-size:12px;text-align:center\">Questions? Call 214-555-0100</p><p style=\"font-size:11px;color:#ccc;text-align:center;margin-top:16px\"></p></div></div>' }}",
        "options": {}
