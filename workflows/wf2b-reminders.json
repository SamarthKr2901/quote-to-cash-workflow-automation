      "parameters": {
        "jsCode": "const esc = $('Split Quote Escs').item.json;\nconst leadArr = $('Fetch Lead Q').item.json;\nconst quoteArr = $input.first().json;\nconst lead = Array.isArray(leadArr) ? (leadArr[0] || {}) : (leadArr || {});\nconst quote = Array.isArray(quoteArr) ? (quoteArr[0] || {}) : (quoteArr || {});\nconst notifCount = esc.notification_count || 0;\nconst dayNum = notifCount + 1;\nconst acceptUrl = 'https://apexwindowstx.com/quote/accept?token=' + (quote.acceptance_token || '');\nconst declineUrl = 'https://apexwindowstx.com/quote/decline?token=' + (quote.acceptance_token || '');\nreturn [{ json: { esc_id: esc.id, lead_id: esc.lead_id, notification_count: notifCount, lead_name: lead.name || 'Customer', lead_email: lead.email || '', quote_id: quote.id || '', total_amount: quote.total_amount || 0, day_num: dayNum, accept_url: acceptUrl, decline_url: declineUrl, is_last_reminder: notifCount >= 2 } }];"
      },
      "id": "merge-q",
      "name": "Merge Quote Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        160
      ]
    },
